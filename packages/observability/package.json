{
  "private": true,
  "name": "@odh-dashboard/observability",
  "description": "Observability plugin for monitoring AI workloads and infrastructure using Perses dashboards.",
  "version": "0.0.0",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test-unit": "jest --silent",
    "test-unit-coverage": "jest --silent --coverage",
    "type-check": "tsc --noEmit"
  },
  "exports": {
    "./extensions": "./extensions.ts"
  },
  "module-federation": {
    "name": "perses",
    "proxyService": [
      {
        "authorize": true,
        "path": "/perses/api",
        "pathRewrite": "",
        "tls": false,
        "service": {
          "name": "data-science-perses",
          "port": 8080
        },
        "localService": {
          "host": "localhost",
          "port": 9005
        }
      }
    ]
  },
  "cypress": {
    "mocked": "cypress/tests/mocked/**/*.cy.ts"
  },
